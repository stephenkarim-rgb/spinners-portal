# Vercel Environment Variables - Set these in Vercel Dashboard

# Security
DEBUG=False
SECRET_KEY=your-secret-key-here (Vercel will auto-generate if not set)

# Hosts
ALLOWED_HOSTS=your-project.vercel.app,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://your-project.vercel.app

# Email (for production, configure a real email service)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Other settings
TIME_ZONE=Africa/Nairobi
